{
  "name": "genius",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "compile": "npx hardhat compile",
    "format": "prettier --write 'contracts/**/*.sol' && prettier --write 'test/*/*' && prettier --write 'utils/*'",
    "size": "npx hardhat size-contracts",
    "validate-genius-config": "node scripts/validate-genius-config.js",
    "increment-days": "yarn hardhat increment-days --network localhost --days",
    "apply-hardhat-deployment-config": "node contracts/v2/scripts/apply-deploy-config.js hardhat",
    "deploy-local-v2": "yarn hardhat run ./contracts/v2/scripts/deploy-local.js --network localhost",
    "deploy-local-v2-with-ui": "./start.sh",
    "test": "npx hardhat test"
  },
  "keywords": [],
  "author": "",
  "license": "GPL-3.0-only",
  "devDependencies": {
    "@nomiclabs/hardhat-ethers": "2.0.6",
    "@nomiclabs/hardhat-waffle": "2.0.3",
    "chai": "4.3.6",
    "ethereum-waffle": "3.4.4",
    "ethers": "5.6.9",
    "hardhat": "2.22.18",
    "hardhat-contract-sizer": "2.6.1",
    "hardhat-gas-reporter": "1.0.8",
    "prettier": "2.7.1",
    "prettier-plugin-solidity": "1.4.2"
  },
  "dependencies": {
    "@openzeppelin/contracts": "4.6.0",
    "bignumber.js": "9.1.2",
    "dotenv": "16.0.2",
    "hardhat-prettier": "0.0.1",
    "keccak256": "1.0.6",
    "lowdb": "1.0.0",
    "merkletreejs": "0.2.32"
  }
